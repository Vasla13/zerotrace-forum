rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    function validPostMediaUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    match /users/{userId}/avatar {
      allow read: if true;
      allow create, update: if isOwner(userId) && validImageUpload(5 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    match /posts/{userId}/{postId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && validPostMediaUpload(25 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }
  }
}
