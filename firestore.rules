rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validPlainText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validAuthor(author) {
      return author is map
        && author.keys().hasOnly(['avatarUrl', 'uid', 'username', 'usernameLower'])
        && author.uid == request.auth.uid
        && (
          !('avatarUrl' in author)
          || author.avatarUrl == null
          || (author.avatarUrl is string && author.avatarUrl.size() <= 2000)
        )
        && validPlainText(author.username, 3, 24)
        && author.usernameLower is string
        && author.usernameLower.matches('^[a-z0-9_]{3,24}$');
    }

    function validSearchKeywords(values) {
      return values is list
        && values.size() >= 1
        && values.size() <= 120;
    }

    function validLikeCount(value) {
      return value is int && value >= 0;
    }

    function validPostMediaItem(item) {
      return item is map
        && item.keys().hasOnly(['storagePath', 'type', 'url'])
        && item.storagePath is string
        && item.storagePath.size() >= 1
        && item.storagePath.size() <= 500
        && item.url is string
        && item.url.size() >= 1
        && item.url.size() <= 2000
        && item.type in ['image', 'video'];
    }

    function validPostMedia(media) {
      return media is list
        && media.size() <= 4
        && (media.size() < 1 || validPostMediaItem(media[0]))
        && (media.size() < 2 || validPostMediaItem(media[1]))
        && (media.size() < 3 || validPostMediaItem(media[2]))
        && (media.size() < 4 || validPostMediaItem(media[3]));
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /admins/{adminUid} {
      allow read, create, update, delete: if false;
    }

    match /accessCodes/{hash} {
      allow read, create, update, delete: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'author',
          'content',
          'createdAt',
          'likeCount',
          'media',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && validAuthor(request.resource.data.author)
        && validPlainText(request.resource.data.title, 6, 120)
        && validPlainText(request.resource.data.content, 20, 5000)
        && validLikeCount(request.resource.data.likeCount)
        && request.resource.data.likeCount == 0
        && validPostMedia(request.resource.data.media)
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isSignedIn()
        && resource.data.author.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'author',
          'content',
          'createdAt',
          'likeCount',
          'media',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && request.resource.data.author == resource.data.author
        && request.resource.data.createdAt == resource.data.createdAt
        && validPlainText(request.resource.data.title, 6, 120)
        && validPlainText(request.resource.data.content, 20, 5000)
        && request.resource.data.likeCount == resource.data.likeCount
        && validPostMedia(request.resource.data.media)
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && validAuthor(request.resource.data.author)
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if isSignedIn()
          && resource.data.author.uid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.author == resource.data.author
          && request.resource.data.createdAt == resource.data.createdAt
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.updatedAt == request.time;

        allow delete: if isSignedIn() && resource.data.author.uid == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }
  }
}
