rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validPlainText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validAuthor(author) {
      return author is map
        && author.keys().hasOnly(['uid', 'username', 'usernameLower'])
        && author.uid == request.auth.uid
        && validPlainText(author.username, 3, 24)
        && author.usernameLower is string
        && author.usernameLower.matches('^[a-z0-9_]{3,24}$');
    }

    function validSearchKeywords(values) {
      return values is list
        && values.size() >= 1
        && values.size() <= 120;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'usernameLower',
          'email',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && validPlainText(request.resource.data.username, 3, 24)
        && request.resource.data.usernameLower is string
        && request.resource.data.usernameLower.matches('^[a-z0-9_]{3,24}$')
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 6
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'usernameLower',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameLower == usernameLower
        && validPlainText(request.resource.data.username, 3, 24)
        && usernameLower.matches('^[a-z0-9_]{3,24}$')
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'author',
          'content',
          'createdAt',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && validAuthor(request.resource.data.author)
        && validPlainText(request.resource.data.title, 6, 120)
        && validPlainText(request.resource.data.content, 20, 5000)
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isSignedIn()
        && resource.data.author.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'author',
          'content',
          'createdAt',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && request.resource.data.author == resource.data.author
        && request.resource.data.createdAt == resource.data.createdAt
        && validPlainText(request.resource.data.title, 6, 120)
        && validPlainText(request.resource.data.content, 20, 5000)
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.updatedAt == request.time;

      allow delete: if isSignedIn() && resource.data.author.uid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && validAuthor(request.resource.data.author)
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if isSignedIn()
          && resource.data.author.uid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.author == resource.data.author
          && request.resource.data.createdAt == resource.data.createdAt
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.updatedAt == request.time;

        allow delete: if isSignedIn() && resource.data.author.uid == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.createdAt == request.time;
        allow delete: if isOwner(userId);
        allow update: if false;
      }
    }
  }
}
