rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCertifiedUser() {
      return isSignedIn()
        && (
          isAdminUser()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.certificationStatus == 'approved'
          )
        );
    }

    function validPlainText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validAuthor(author) {
      return author is map
        && author.keys().hasOnly(['avatarUrl', 'uid', 'username', 'usernameLower'])
        && author.uid == request.auth.uid
        && (
          !('avatarUrl' in author)
          || author.avatarUrl == null
          || (author.avatarUrl is string && author.avatarUrl.size() <= 2000)
        )
        && validPlainText(author.username, 3, 24)
        && author.usernameLower is string
        && author.usernameLower.matches('^[a-z0-9_]{3,24}$');
    }

    function validSearchKeywords(values) {
      return values is list
        && values.size() <= 120;
    }

    function validLikeCount(value) {
      return value is int && value >= 0;
    }

    function validPostMediaItem(item) {
      return item is map
        && item.keys().hasOnly(['storagePath', 'type', 'url'])
        && item.storagePath is string
        && item.storagePath.size() >= 1
        && item.storagePath.size() <= 500
        && item.url is string
        && item.url.size() >= 1
        && item.url.size() <= 2000
        && item.type in ['image', 'video'];
    }

    function validPostMedia(media) {
      return media is list
        && media.size() <= 4
        && (media.size() < 1 || validPostMediaItem(media[0]))
        && (media.size() < 2 || validPostMediaItem(media[1]))
        && (media.size() < 3 || validPostMediaItem(media[2]))
        && (media.size() < 4 || validPostMediaItem(media[3]));
    }

    function validChannel(value) {
      return value in ['general', 'fuites', 'matos', 'terrain'];
    }

    function validRealm(value) {
      return value in ['public', 'certified'];
    }

    function validDisplayMode(value) {
      return value in ['standard', 'media'];
    }

    function postRealm(postData) {
      return ('realm' in postData) && postData.realm == 'certified'
        ? 'certified'
        : 'public';
    }

    function canAccessRealm(realm) {
      return realm == 'public'
        || (realm == 'certified' && isCertifiedUser());
    }

    function validMediaFlags(hasMedia, mediaCount, media) {
      return hasMedia is bool
        && mediaCount is int
        && mediaCount == media.size()
        && hasMedia == (mediaCount > 0);
    }

    function validPostBody(title, content, displayMode) {
      return displayMode == 'standard'
        ? validPlainText(title, 6, 120) && validPlainText(content, 20, 5000)
        : (title is string && title.size() <= 120)
          && validPlainText(content, 2, 280);
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /admins/{adminUid} {
      allow read, create, update, delete: if false;
    }

    match /accessCodes/{hash} {
      allow read, create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read, create, update, delete: if false;
    }

    match /posts/{postId} {
      allow read: if canAccessRealm(postRealm(resource.data));
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'author',
          'channel',
          'content',
          'createdAt',
          'displayMode',
          'hasMedia',
          'isPinned',
          'likeCount',
          'media',
          'mediaCount',
          'realm',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && validAuthor(request.resource.data.author)
        && validChannel(request.resource.data.channel)
        && validDisplayMode(request.resource.data.displayMode)
        && validRealm(request.resource.data.realm)
        && canAccessRealm(request.resource.data.realm)
        && validPostBody(
          request.resource.data.title,
          request.resource.data.content,
          request.resource.data.displayMode
        )
        && validLikeCount(request.resource.data.likeCount)
        && request.resource.data.likeCount == 0
        && validPostMedia(request.resource.data.media)
        && validMediaFlags(
          request.resource.data.hasMedia,
          request.resource.data.mediaCount,
          request.resource.data.media
        )
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.isPinned == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isSignedIn()
        && resource.data.author.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'author',
          'channel',
          'content',
          'createdAt',
          'displayMode',
          'hasMedia',
          'isPinned',
          'likeCount',
          'media',
          'mediaCount',
          'realm',
          'searchKeywords',
          'title',
          'updatedAt'
        ])
        && request.resource.data.author == resource.data.author
        && request.resource.data.createdAt == resource.data.createdAt
        && validChannel(request.resource.data.channel)
        && validDisplayMode(request.resource.data.displayMode)
        && request.resource.data.realm == resource.data.realm
        && canAccessRealm(request.resource.data.realm)
        && validPostBody(
          request.resource.data.title,
          request.resource.data.content,
          request.resource.data.displayMode
        )
        && request.resource.data.likeCount == resource.data.likeCount
        && validPostMedia(request.resource.data.media)
        && validMediaFlags(
          request.resource.data.hasMedia,
          request.resource.data.mediaCount,
          request.resource.data.media
        )
        && validSearchKeywords(request.resource.data.searchKeywords)
        && request.resource.data.isPinned == resource.data.isPinned
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;

      match /comments/{commentId} {
        allow read: if canAccessRealm(postRealm(get(/databases/$(database)/documents/posts/$(postId)).data));
        allow create: if isSignedIn()
          && canAccessRealm(postRealm(get(/databases/$(database)/documents/posts/$(postId)).data))
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && validAuthor(request.resource.data.author)
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if isSignedIn()
          && canAccessRealm(postRealm(get(/databases/$(database)/documents/posts/$(postId)).data))
          && resource.data.author.uid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'author',
            'content',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.author == resource.data.author
          && request.resource.data.createdAt == resource.data.createdAt
          && validPlainText(request.resource.data.content, 2, 1000)
          && request.resource.data.updatedAt == request.time;

        allow delete: if isSignedIn()
          && canAccessRealm(postRealm(get(/databases/$(database)/documents/posts/$(postId)).data))
          && resource.data.author.uid == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if isOwner(userId)
          && canAccessRealm(postRealm(get(/databases/$(database)/documents/posts/$(postId)).data));
        allow create, update, delete: if false;
      }
    }
  }
}
